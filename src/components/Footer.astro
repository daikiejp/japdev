---
const { title, hasSidebar = false } = Astro.props;
---
<!-- フッター -->
<footer style="background-color: var(--bg-footer); border-top-color: var(--border-footer);" class={`border-t mt-16 ${hasSidebar ? "lg:ml-64" : ""}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div>
        <h4 style="color: var(--text-primary);" class="font-bold mb-3">JapDev</h4>
        <p style="color: var(--text-secondary);" class="text-md wrap-break-words">開発者のための最新情報をお届けします</p>
      </div>
      <div>
        <h4 style="color: var(--text-primary);" class="font-bold mb-3">コンテンツ</h4>
        <ul class="space-y-2 text-md" style="color: var(--text-secondary);">
          <li><a href="/" class="hover:text-emerald-600">チートシート</a></li>
          <li><a href="/versions" class="hover:text-emerald-600">最新バージョン</a></li>
          <li><a href="/resources" class="hover:text-emerald-600">リソース</a></li>
        </ul>
      </div>
      <div>
        <h4 style="color: var(--text-primary);" class="font-bold mb-3">プロジェクト情報</h4>
        <ul class="space-y-2 text-md" style="color: var(--text-secondary);">
          <li><a href="/about" class="hover:text-emerald-600">私たちについて</a></li>
          <li><a href="/terms" class="hover:text-emerald-600">利用規約</a></li>
          <li><a href="/privacy" class="hover:text-emerald-600">プライバシー</a></li>
        </ul>
      </div>
      <div>
        <h4 style="color: var(--text-primary);" class="font-bold mb-3">リンク</h4>
        <ul class="space-y-2 text-md" style="color: var(--text-secondary);">
          <li><a href="https://github.com/daikiejp/japdev" class="hover:text-emerald-600">Github</a></li>
        </ul>
      </div>
    </div>
    <div style="border-top-color: var(--border-footer); color: var(--text-secondary);" class="border-t pt-8 text-center text-sm">
      <p>© 2025 - 2026 JapDev. MITライセンスのもとで公開。作成者：<a href="https://daikie.jp" class="hover:text-emerald-600">ダニー・ダビラ（だいきえ）</a></p>
      <p>開発者の愛を込めて、開発者のために作られました。</p>
    </div>
  </div>
</footer>
